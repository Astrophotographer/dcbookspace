# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000

# /admin 페이지 쿠키 세션 로그인 (env 비밀번호는 비상용 — DB 비밀번호 분실 시 우회 로그인 가능)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# 쿠키 세션 서명용 secret. 16자 이상 랜덤 문자열 권장. 빈 값이면 /admin 진입 시 503.
# 결재자 5분 자동 세션 쿠키 서명에도 같은 secret 사용 — 비어 있으면 자동 세션 비활성, 매 QR마다 PIN 필요.
# 생성 예: openssl rand -hex 32
APPROVAL_SESSION_SECRET=

# 외부 공간 조회 API (/api/v1/*) 인증 토큰. 비어 있어도 동작하지만 외부 노출 시 토큰 설정 강력 권장.
# 클라이언트 호출 시 `Authorization: Bearer <token>` 헤더로 전달.
EXTERNAL_API_TOKEN=

# 사무실 NAS 도커 프린트 에이전트 ↔ 서버 인증 토큰. /api/print/jobs · /api/print/status 보호.
# 에이전트 컨테이너 환경변수와 동일하게 맞춰야 함.
PRINT_AGENT_TOKEN=

# 웹훅(결재 완료·출력 오류 등) 발송 시 페이로드 서명용 secret. HMAC-SHA256.
# 수신 측(n8n / Slack / Telegram bridge 등)에서 X-DCB-Signature 헤더 검증에 사용.
WEBHOOK_SECRET=

# 웹훅 발송 대상 URL 목록. 콤마 구분 여러 개 가능. 비어있으면 발송 비활성.
# 예: https://hooks.slack.com/services/xxx,https://n8n.example.com/webhook/abc
WEBHOOK_TARGETS=

# PWA 푸시 알림 (Web Push) VAPID 키 페어. 비어있으면 푸시 비활성 (앱은 정상 동작).
# 생성: node -e "const wp=require('web-push');const k=wp.generateVAPIDKeys();console.log('PUB:',k.publicKey);console.log('PRIV:',k.privateKey)"
# PUBLIC 은 클라이언트 번들에도 노출되므로 NEXT_PUBLIC_ 으로도 같은 값 등록 필요.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# RFC 8292 — mailto: 또는 https:// URL. 푸시 서비스가 발신자 식별에 사용.
VAPID_SUBJECT=mailto:admin@deungchon.org

# Telegram 알림 자가 등록 (/me/telegram) — deep-link 자동 흐름용.
# TELEGRAM_BOT_TOKEN 이 비어 있으면 직접 발송과 자동 연결이 비활성.
# NEXT_PUBLIC_ 값은 선택. 비워두면 서버가 TELEGRAM_BOT_TOKEN 으로 getMe 호출해 자동 확인.
# TELEGRAM_WEBHOOK_SECRET_TOKEN 은 Telegram setWebhook secret_token 과 같은 값.
# 생성 예: openssl rand -hex 32
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET_TOKEN=
# 선택 fallback: BotFather 로 만든 봇 username 만 (@ 빼고) 적기. 예: PlaceUseRequestBot
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=

# 선택: n8n 자동 등록 워크플로우(B) → /api/telegram/link POST 인증용 Bearer 토큰.
# 32자 이상 임의 문자열 권장. 생성: openssl rand -hex 32
TELEGRAM_LINK_SECRET=
