# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000

# /admin 페이지 BasicAuth 보호 (없으면 503)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# 결재자 5분 자동 세션 (PIN 한 번 입력 후 5분간 같은 휴대폰의 다른 QR 자동 승인)
# 16자 이상 랜덤 문자열 권장. 비어 있으면 자동 세션 비활성, 매 QR마다 PIN 필요.
# 생성 예: openssl rand -hex 32
APPROVAL_SESSION_SECRET=
