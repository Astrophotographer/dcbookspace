# 이 파일을 .env 로 복사하고 값 채우기.

# Vercel 사이트 URL (끝에 슬래시 X)
APP_BASE_URL=https://dcbookspace.vercel.app

# /api/print/* 호출 시 Authorization 헤더에 실어 보낼 비밀 토큰.
# Vercel Project Settings → Environment Variables 에 같은 값으로 PRINT_AGENT_TOKEN 등록.
# 안전한 랜덤 32~64자 추천.
PRINT_AGENT_TOKEN=replace-with-long-random-secret

# Sindoh D450 의 LAN IP. 라우터에서 DHCP 예약으로 고정 권장.
PRINTER_HOST=192.168.0.50

# Raw 9100 포트 (보통 그대로 9100)
PRINTER_PORT=9100

# 폴링 주기 (초). 사용량 많으면 3~5초, 한가하면 10~30초.
POLL_INTERVAL_SEC=5
