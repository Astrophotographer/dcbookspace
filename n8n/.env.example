# n8n self-host sample env for 장소사용신청서.
# Copy to n8n/.env and fill secrets before running docker compose.

# n8n/Postgres persistence
POSTGRES_USER=n8n
POSTGRES_PASSWORD=replace-with-long-random-password
POSTGRES_DB=n8n
N8N_ENCRYPTION_KEY=replace-with-openssl-rand-hex-32

# Public n8n URL. For production, use a real HTTPS URL, usually a subdomain.
# Local-only example:
N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_PORT=5678
WEBHOOK_URL=http://localhost:5678/
N8N_EDITOR_BASE_URL=http://localhost:5678/
N8N_SECURE_COOKIE=false

# Korea church operation timezone.
GENERIC_TIMEZONE=Asia/Seoul
TZ=Asia/Seoul

# 장소사용신청서 integration values.
# SITE_URL should point to the 장소사용신청서 environment this n8n talks to.
# Local Docker on macOS can reach the Next dev server through host.docker.internal.
SITE_URL=http://host.docker.internal:3000
WEBHOOK_SECRET=replace-with-same-value-as-dcbookspace
TELEGRAM_LINK_SECRET=replace-with-same-value-as-dcbookspace

# Optional fallback target for operational alerts.
OFFICE_CHAT_ID=
