# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# supabase CLI 캐시 (프로젝트 ref / org id 등 식별자 포함)
supabase/.temp
supabase/.branches

# typescript
*.tsbuildinfo
next-env.d.ts
